# Ecodex — Affinity Claims Click Detection (Section 14)
# Run as: player with menu open

# Auto-refresh every 60 ticks
execute store result score #ms_refresh ec.temp run time query gametime
scoreboard players operation #ms_refresh ec.temp %= #60 ec.const
execute if score #ms_refresh ec.temp matches 0 run function evercraft:ecodex/sections/affinity_claims/refresh

# Claim clicks
execute as @e[type=interaction,tag=Ec.AffCl1,distance=..5] if score @s adv.gui_session = #gui_owner ec.temp if data entity @s interaction run function evercraft:ecodex/sections/affinity_claim_click {cls:"rg",t1:"common",t2:"uncommon",t3:"rare",t4:"ornate",t5:"exquisite",t6:"mythical",t7:"mythical",c1:5,c2:10,c3:15,c4:25,c5:35,c6:50,c7:75}
