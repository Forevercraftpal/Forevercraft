# Artifact Collection — Refresh Starweaver Constellation
# Checks advancements and updates display text
# Run as the player

execute if entity @s[advancements={evercraft:artifacts/collected/ender_helmet=true}] run data modify entity @e[type=text_display,tag=Adv.ArtI_ender_helmet,limit=1,sort=nearest] text set value [{text:"\u2713 ",color:"green"},{text:"Ender Helmet",color:"white"}]
execute unless entity @s[advancements={evercraft:artifacts/collected/ender_helmet=true}] unless entity @s[tag=ec.wishing_star_active] run data modify entity @e[type=text_display,tag=Adv.ArtI_ender_helmet,limit=1,sort=nearest] text set value {text:"? ???",color:"dark_gray"}
execute unless entity @s[advancements={evercraft:artifacts/collected/ender_helmet=true}] if entity @s[tag=ec.wishing_star_active] run data modify entity @e[type=text_display,tag=Adv.ArtI_ender_helmet,limit=1,sort=nearest] text set value [{text:"\u2606 ",color:"yellow"},{text:"Ender Helmet",color:"white"}]
