# Artifact Collection — Refresh Frozen Veil Constellation
# Checks advancements and updates display text
# Run as the player

execute if entity @s[advancements={evercraft:artifacts/collected/frost_helmet=true}] run data modify entity @e[type=text_display,tag=Adv.ArtI_frost_helmet,limit=1,sort=nearest] text set value [{text:"\u2713 ",color:"green"},{text:"Frost Helmet",color:"white"}]
execute unless entity @s[advancements={evercraft:artifacts/collected/frost_helmet=true}] unless entity @s[tag=ec.wishing_star_active] run data modify entity @e[type=text_display,tag=Adv.ArtI_frost_helmet,limit=1,sort=nearest] text set value {text:"? ???",color:"dark_gray"}
