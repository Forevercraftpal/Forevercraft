# Find the placed barrel nearby and start animation
execute positioned ~ ~1.6 ~ run function evercraft:crate_anim/find_placed_barrel {tier:"mythical",system_tag:"fishing_crate",plot_start:30,skin:"",nbt_key:"fc_rarity",nbt_val:"mythical"}
