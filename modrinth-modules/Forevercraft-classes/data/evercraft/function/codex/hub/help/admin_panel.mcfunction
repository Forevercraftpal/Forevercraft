# Codex Hub — Help Guide — Admin Panel (tellraw to chat)
# Run as the player (@s = player)
# Gated behind ec.admin tag

# Admin gate
execute unless entity @s[tag=ec.admin] run tellraw @s [{text:"[Admin] ",color:"dark_red"},{text:"Access denied. Use ",color:"gray"},{text:"/tag @s add ec.admin",color:"yellow"},{text:" (requires op)",color:"gray"}]
execute unless entity @s[tag=ec.admin] at @s run playsound minecraft:block.note_block.bass master @s ~ ~ ~ 0.8 0.5
execute unless entity @s[tag=ec.admin] run return 0

# Sound
playsound minecraft:ui.button.click master @s ~ ~ ~ 0.5 1.0

# === ADMIN COMMAND PANEL ===
tellraw @s ""
tellraw @s [{text:"  "},{text:"✦ ADMIN COMMANDS ✦",color:"red",bold:true}]
