# Guild Expedition — Get Biome Name
# Input: #gexp_biome_id ec.temp (0-24)
# Output: evercraft:expedition temp.biome_name (string)

data modify storage evercraft:expedition temp.biome_name set value "Unknown"
execute if score #gexp_biome_id ec.temp matches 0 run data modify storage evercraft:expedition temp.biome_name set value "Plains"
execute if score #gexp_biome_id ec.temp matches 1 run data modify storage evercraft:expedition temp.biome_name set value "Forest"
