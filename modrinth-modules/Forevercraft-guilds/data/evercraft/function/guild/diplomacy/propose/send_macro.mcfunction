# Guild Diplomacy — Announce vote to both guilds
# $(guild_a) $(guild_b) $(vote_type) $(guild_a_name) $(guild_b_name)

# Alliance announcement (vote_type=1)
$execute if score #gd_vote_type ec.var matches 1 as @a[scores={ec.guild_id=$(guild_a)}] run tellraw @s [{text:"[Forevercraft] ",color:"gold"},{text:"Alliance proposed with ",color:"yellow"},{text:"$(guild_b_name)",color:"gold",bold:true},{text:"! ",color:"yellow"},{text:"[Vote Yes]",color:"green",bold:true,click_event:{action:"run_command",command:"/trigger ec.gd_diplo set 4"},hover_event:{action:"show_text",value:{text:"Vote to form alliance"}}},{text:" "},{text:"[Vote No]",color:"red",bold:true,click_event:{action:"run_command",command:"/trigger ec.gd_diplo set 5"},hover_event:{action:"show_text",value:{text:"Vote against alliance"}}}]

$execute if score #gd_vote_type ec.var matches 1 as @a[scores={ec.guild_id=$(guild_b)}] run tellraw @s [{text:"[Forevercraft] ",color:"gold"},{text:"$(guild_a_name)",color:"gold",bold:true},{text:" proposes an Alliance! ",color:"yellow"},{text:"[Vote Yes]",color:"green",bold:true,click_event:{action:"run_command",command:"/trigger ec.gd_diplo set 4"},hover_event:{action:"show_text",value:{text:"Vote to form alliance"}}},{text:" "},{text:"[Vote No]",color:"red",bold:true,click_event:{action:"run_command",command:"/trigger ec.gd_diplo set 5"},hover_event:{action:"show_text",value:{text:"Vote against alliance"}}}]

