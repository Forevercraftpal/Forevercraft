# Competition Announce — Fishing Derby+
bossbar set minecraft:competition name [{text:"Fishing Derby+",color:"gold",bold:true},{text:" — Catch fish!",color:"yellow"}]

title @a times 10 60 20
title @a title {text:"Fishing Derby+!",color:"gold",bold:true}
title @a subtitle {text:"Catch as many fish as possible!",color:"yellow"}

tellraw @a [{text:"",color:"dark_gray",strikethrough:true,extra:[{text:"                                        ",strikethrough:true}]}]
tellraw @a [{text:"  ",color:"gold"},{text:"FISHING DERBY+",color:"gold",bold:true}]
tellraw @a [{text:"  Catch fish for points!",color:"yellow"}]
tellraw @a [{text:"  +1 per fish, +3 per treasure",color:"gray"}]
tellraw @a [{text:"  Dream Rate +0.5 while fishing",color:"green"}]
tellraw @a [{text:"  Duration: 5 minutes",color:"dark_gray"}]
tellraw @a [{text:"",color:"dark_gray",strikethrough:true,extra:[{text:"                                        ",strikethrough:true}]}]
