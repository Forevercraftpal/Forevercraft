# Artisan Rank — Display title on actionbar (macro)
# Called with storage evercraft:craftforever {rank_val:N}

$execute if score @s ec.cf_rank matches 1..4 run title @s actionbar [{text:"Artisan Rank $(rank_val)",color:"gray"},{text:" — Novice",color:"white"}]
$execute if score @s ec.cf_rank matches 5..9 run title @s actionbar [{text:"Artisan Rank $(rank_val)",color:"gray"},{text:" — Initiate",color:"white"}]
$execute if score @s ec.cf_rank matches 10..14 run title @s actionbar [{text:"Artisan Rank $(rank_val)",color:"yellow"},{text:" — Apprentice",color:"white"}]
$execute if score @s ec.cf_rank matches 15..19 run title @s actionbar [{text:"Artisan Rank $(rank_val)",color:"yellow"},{text:" — Craftsman",color:"white"}]
$execute if score @s ec.cf_rank matches 20..24 run title @s actionbar [{text:"Artisan Rank $(rank_val)",color:"green"},{text:" — Journeyman",color:"white"}]
$execute if score @s ec.cf_rank matches 25..29 run title @s actionbar [{text:"Artisan Rank $(rank_val)",color:"green"},{text:" — Adept",color:"white"}]
$execute if score @s ec.cf_rank matches 30..34 run title @s actionbar [{text:"Artisan Rank $(rank_val)",color:"aqua"},{text:" — Artisan",color:"white"}]
$execute if score @s ec.cf_rank matches 35..39 run title @s actionbar [{text:"Artisan Rank $(rank_val)",color:"aqua"},{text:" — Specialist",color:"white"}]
$execute if score @s ec.cf_rank matches 40..44 run title @s actionbar [{text:"Artisan Rank $(rank_val)",color:"blue"},{text:" — Expert",color:"white"}]
$execute if score @s ec.cf_rank matches 45..49 run title @s actionbar [{text:"Artisan Rank $(rank_val)",color:"blue"},{text:" — Sage",color:"white"}]
$execute if score @s ec.cf_rank matches 50..54 run title @s actionbar [{text:"Artisan Rank $(rank_val)",color:"light_purple"},{text:" — Master",color:"yellow"}]
$execute if score @s ec.cf_rank matches 55..59 run title @s actionbar [{text:"Artisan Rank $(rank_val)",color:"light_purple"},{text:" — Grandmaster",color:"yellow"}]
$execute if score @s ec.cf_rank matches 60..64 run title @s actionbar [{text:"Artisan Rank $(rank_val)",color:"gold"},{text:" — Luminary",color:"yellow"}]
$execute if score @s ec.cf_rank matches 65..69 run title @s actionbar [{text:"Artisan Rank $(rank_val)",color:"gold"},{text:" — Visionary",color:"yellow"}]
$execute if score @s ec.cf_rank matches 70..74 run title @s actionbar [{text:"Artisan Rank $(rank_val)",color:"gold"},{text:" — Paragon",color:"gold"}]
$execute if score @s ec.cf_rank matches 75..79 run title @s actionbar [{text:"Artisan Rank $(rank_val)",color:"gold"},{text:" — Sage Master",color:"gold"}]
$execute if score @s ec.cf_rank matches 80..84 run title @s actionbar [{text:"Artisan Rank $(rank_val)",color:"gold"},{text:" — Archon",color:"gold"}]
$execute if score @s ec.cf_rank matches 85..89 run title @s actionbar [{text:"Artisan Rank $(rank_val)",color:"gold"},{text:" — Legend",color:"gold"}]
$execute if score @s ec.cf_rank matches 90..94 run title @s actionbar [{text:"Artisan Rank $(rank_val)",color:"gold",bold:true},{text:" — Mythic",color:"gold"}]
$execute if score @s ec.cf_rank matches 95..99 run title @s actionbar [{text:"Artisan Rank $(rank_val)",color:"gold",bold:true},{text:" — Eternal",color:"gold"}]
$execute if score @s ec.cf_rank matches 100 run title @s actionbar [{text:"Artisan Rank $(rank_val)",color:"gold",bold:true},{text:" — Eternal Crafter",color:"gold",bold:true}]
