# Earthsong — Uncommon → Rare (6 objectives)
execute if score @s ec.tq_mine_stone matches 500.. run scoreboard players add @s ec.st_obj_done 1
execute if score @s ec.tq_mine_iron matches 100.. run scoreboard players add @s ec.st_obj_done 1
execute if score @s ec.tq_mine_dia matches 25.. run scoreboard players add @s ec.st_obj_done 1
execute if score @s ec.tq_mine_ds matches 200.. run scoreboard players add @s ec.st_obj_done 1
execute if score @s ach.biomes_visited matches 5.. run scoreboard players add @s ec.st_obj_done 1
execute if score @s ec.cf_rank matches 3.. run scoreboard players add @s ec.st_obj_done 1
