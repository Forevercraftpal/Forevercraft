# Route quests 1-50
execute if score @s ec.tq_part matches 1..10 run function evercraft:craftforever/spirit_tools/tome/quests/route/parts_1_10
execute if score @s ec.tq_part matches 11..20 run function evercraft:craftforever/spirit_tools/tome/quests/route/parts_11_20
execute if score @s ec.tq_part matches 21..30 run function evercraft:craftforever/spirit_tools/tome/quests/route/parts_21_30
execute if score @s ec.tq_part matches 31..40 run function evercraft:craftforever/spirit_tools/tome/quests/route/parts_31_40
execute if score @s ec.tq_part matches 41..50 run function evercraft:craftforever/spirit_tools/tome/quests/route/parts_41_50
