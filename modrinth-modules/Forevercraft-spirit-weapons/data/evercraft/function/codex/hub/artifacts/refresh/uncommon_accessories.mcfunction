# Artifact Collection — Refresh Uncommon Accessories
# Checks advancements and updates display text
# Run as the player

execute if entity @s[advancements={evercraft:artifacts/collected/featherweight_stone=true}] run data modify entity @e[type=text_display,tag=Adv.ArtI_featherweight_stone,limit=1,sort=nearest] text set value [{text:"\u2713 ",color:"green"},{text:"Featherweight Stone",color:"dark_blue"}]
execute unless entity @s[advancements={evercraft:artifacts/collected/featherweight_stone=true}] unless entity @s[tag=ec.wishing_star_active] run data modify entity @e[type=text_display,tag=Adv.ArtI_featherweight_stone,limit=1,sort=nearest] text set value {text:"? ???",color:"dark_gray"}
execute unless entity @s[advancements={evercraft:artifacts/collected/featherweight_stone=true}] if entity @s[tag=ec.wishing_star_active] run data modify entity @e[type=text_display,tag=Adv.ArtI_featherweight_stone,limit=1,sort=nearest] text set value [{text:"\u2606 ",color:"yellow"},{text:"Featherweight Stone",color:"dark_blue"}]
