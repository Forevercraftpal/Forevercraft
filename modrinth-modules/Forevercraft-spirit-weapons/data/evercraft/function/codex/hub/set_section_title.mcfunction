# Codex Hub — Set Section Title
# Updates the title text_display based on adv.gui_section scoreboard
# Run as the player

# Update title via anchor proximity
scoreboard players operation #gui_stamp ec.temp = @s adv.gui_session

execute if score @s adv.gui_section matches 1 as @e[type=marker,tag=Adv.MenuAnchor,distance=..5] if score @s adv.gui_session = #gui_stamp ec.temp at @s run data modify entity @e[type=text_display,tag=Adv.MenuTitle,distance=..5,limit=1] text set value {text:"\u2726 Advantage Trees \u2726",color:"gold",bold:true}
