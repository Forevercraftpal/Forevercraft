# Artifact Collection — Refresh Mythical Accessories
# Checks advancements and updates display text
# Run as the player

execute if entity @s[advancements={evercraft:artifacts/collected/beacon_of_ancients=true}] run data modify entity @e[type=text_display,tag=Adv.ArtI_beacon_of_ancients,limit=1,sort=nearest] text set value [{text:"\u2713 ",color:"green"},{text:"Beacon of the Ancients",color:"gold"}]
