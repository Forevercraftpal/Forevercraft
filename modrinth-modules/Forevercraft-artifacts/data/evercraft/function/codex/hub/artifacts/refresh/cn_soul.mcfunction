# Artifact Collection — Refresh Soulbinder Constellation
# Checks advancements and updates display text
# Run as the player

execute if entity @s[advancements={evercraft:artifacts/collected/wither_helmet=true}] run data modify entity @e[type=text_display,tag=Adv.ArtI_wither_helmet,limit=1,sort=nearest] text set value [{text:"\u2713 ",color:"green"},{text:"Wither Helmet",color:"white"}]
