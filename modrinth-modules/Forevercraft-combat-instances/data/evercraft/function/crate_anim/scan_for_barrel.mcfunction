# Scan for a newly placed crate barrel near the player
# Macro args: $(tier), $(system_tag), $(plot_start), $(skin), $(nbt_key), $(nbt_val)
# Run as: the player with tag ec.searching, positioned at their feet (block-aligned)
# $(nbt_key)/"$(nbt_val)" validates the barrel's custom_data matches the placed crate
# Scans 339 positions within placement reach, closest first

# Y=0 (feet level)
$execute if entity @s[tag=ec.searching] positioned ~0 ~0 ~0 if block ~ ~ ~ minecraft:barrel if data block ~ ~ ~ {components:{"minecraft:custom_data":{$(nbt_key):"$(nbt_val)"}}} unless entity @n[type=armor_stand,tag=ec.crate_anim,distance=..0.5] run function evercraft:crate_anim/lock_and_animate {tier:"$(tier)",system_tag:"$(system_tag)",plot_start:$(plot_start),skin:"$(skin)"}
