# Daily Challenge — Map modifier ID to atmospheric flavor hint
# Stores vague hint text to evercraft:daily_challenge flavor.modifier

execute if score #dc_modifier ec.var matches 1 run data modify storage evercraft:daily_challenge flavor.modifier set value "and what lurks within moves with unnatural haste."
execute if score #dc_modifier ec.var matches 2 run data modify storage evercraft:daily_challenge flavor.modifier set value "and its denizens wear hides thick as iron."
execute if score #dc_modifier ec.var matches 3 run data modify storage evercraft:daily_challenge flavor.modifier set value "and a suffocating darkness swallows all light."
execute if score #dc_modifier ec.var matches 4 run data modify storage evercraft:daily_challenge flavor.modifier set value "and the ground itself seems to anchor the beasts within."
execute if score #dc_modifier ec.var matches 5 run data modify storage evercraft:daily_challenge flavor.modifier set value "and wounds knit shut before your eyes."
execute if score #dc_modifier ec.var matches 6 run data modify storage evercraft:daily_challenge flavor.modifier set value "and a savage fury drives every blow."
