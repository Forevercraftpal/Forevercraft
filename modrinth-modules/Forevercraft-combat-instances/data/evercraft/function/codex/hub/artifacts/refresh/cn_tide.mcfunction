# Artifact Collection — Refresh Tidewalker Constellation
# Checks advancements and updates display text
# Run as the player

execute if entity @s[advancements={evercraft:artifacts/collected/ocean_helmet=true}] run data modify entity @e[type=text_display,tag=Adv.ArtI_ocean_helmet,limit=1,sort=nearest] text set value [{text:"\u2713 ",color:"green"},{text:"Prismarine Helmet",color:"white"}]
