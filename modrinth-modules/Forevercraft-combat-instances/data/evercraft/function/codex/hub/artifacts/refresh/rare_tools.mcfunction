# Artifact Collection — Refresh Rare Tools
# Checks advancements and updates display text
# Run as the player

execute if entity @s[advancements={evercraft:artifacts/collected/fantasy_pickaxe=true}] run data modify entity @e[type=text_display,tag=Adv.ArtI_fantasy_pickaxe,limit=1,sort=nearest] text set value [{text:"\u2713 ",color:"green"},{text:"Fantasy Pickaxe",color:"aqua"}]
execute unless entity @s[advancements={evercraft:artifacts/collected/fantasy_pickaxe=true}] unless entity @s[tag=ec.wishing_star_active] run data modify entity @e[type=text_display,tag=Adv.ArtI_fantasy_pickaxe,limit=1,sort=nearest] text set value {text:"? ???",color:"dark_gray"}
execute unless entity @s[advancements={evercraft:artifacts/collected/fantasy_pickaxe=true}] if entity @s[tag=ec.wishing_star_active] run data modify entity @e[type=text_display,tag=Adv.ArtI_fantasy_pickaxe,limit=1,sort=nearest] text set value [{text:"\u2606 ",color:"yellow"},{text:"Fantasy Pickaxe",color:"aqua"}]
