# Artifact Collection — Refresh Shadow's Edge Constellation
# Checks advancements and updates display text
# Run as the player

execute if entity @s[advancements={evercraft:artifacts/collected/shadow_helmet=true}] run data modify entity @e[type=text_display,tag=Adv.ArtI_shadow_helmet,limit=1,sort=nearest] text set value [{text:"\u2713 ",color:"green"},{text:"Shadow Walker Helmet",color:"white"}]
