# Pantry — Withdraw all non-empty slots to player inventory (macro)
# Args: pid
# For each slot with an item, summon it as a pickup item and clear the slot

$execute if data storage evercraft:pantry bags.$(pid).s0.item run function evercraft:pantry/withdraw_slot {pid:"$(pid)",slot:"s0"}
