# Guild Menu — Spawn single ally row (macro)
# $(ally_name) $(ally_id) $(ally_row)
# Anchored to bg entity to prevent shift when player rotates to click tabs
# Row Y offsets from bg: 0=+0.18, 1=+0.04, 2=-0.10, 3=-0.24

# Guild name text
$execute if score #ally_row ec.temp matches 0 at @e[type=item_display,tag=ec.guild_menu_bg,distance=..5,limit=1] positioned ^0.12 ^0.25 ^-0.02 run summon text_display ~ ~ ~ {brightness:{block:15,sky:15},shadow_radius:0f, Tags:["ec.guild_menu_el","ec.guild_page_el"], billboard:"center", text:{text:"$(ally_name)",color:"gold"}, background:1, shadow:1b, transformation:{left_rotation:[0f,0f,0f,1f],right_rotation:[0f,0f,0f,1f],translation:[0f,0f,0f],scale:[0.338f,0.338f,0.338f]} }
$execute if score #ally_row ec.temp matches 1 at @e[type=item_display,tag=ec.guild_menu_bg,distance=..5,limit=1] positioned ^0.12 ^0.11 ^-0.02 run summon text_display ~ ~ ~ {brightness:{block:15,sky:15},shadow_radius:0f, Tags:["ec.guild_menu_el","ec.guild_page_el"], billboard:"center", text:{text:"$(ally_name)",color:"gold"}, background:1, shadow:1b, transformation:{left_rotation:[0f,0f,0f,1f],right_rotation:[0f,0f,0f,1f],translation:[0f,0f,0f],scale:[0.338f,0.338f,0.338f]} }
$execute if score #ally_row ec.temp matches 2 at @e[type=item_display,tag=ec.guild_menu_bg,distance=..5,limit=1] positioned ^0.12 ^-0.03 ^-0.02 run summon text_display ~ ~ ~ {brightness:{block:15,sky:15},shadow_radius:0f, Tags:["ec.guild_menu_el","ec.guild_page_el"], billboard:"center", text:{text:"$(ally_name)",color:"gold"}, background:1, shadow:1b, transformation:{left_rotation:[0f,0f,0f,1f],right_rotation:[0f,0f,0f,1f],translation:[0f,0f,0f],scale:[0.338f,0.338f,0.338f]} }
$execute if score #ally_row ec.temp matches 3 at @e[type=item_display,tag=ec.guild_menu_bg,distance=..5,limit=1] positioned ^0.12 ^-0.17 ^-0.02 run summon text_display ~ ~ ~ {brightness:{block:15,sky:15},shadow_radius:0f, Tags:["ec.guild_menu_el","ec.guild_page_el"], billboard:"center", text:{text:"$(ally_name)",color:"gold"}, background:1, shadow:1b, transformation:{left_rotation:[0f,0f,0f,1f],right_rotation:[0f,0f,0f,1f],translation:[0f,0f,0f],scale:[0.338f,0.338f,0.338f]} }

