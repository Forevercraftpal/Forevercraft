$execute if data storage eden:settings bestiary.villager_settings{villagecenter_healing:"daytime"} as @e[type=#$(validmobs)] at @s unless predicate evercraft:mobs/time/night_time if entity @e[type=armor_stand,tag=bestiary.village.name,distance=..$(village_heal_distance)] run effect give @s regeneration 5 0 true
$execute if data storage eden:settings bestiary.villager_settings{villagecenter_healing:"nighttime"} as @e[type=#$(validmobs)] at @s if predicate evercraft:mobs/time/night_time if entity @e[type=armor_stand,tag=bestiary.village.name,distance=..$(village_heal_distance)] run effect give @s regeneration 5 0 true
$execute if data storage eden:settings bestiary.villager_settings{villagecenter_healing:"always"} as @e[type=#$(validmobs)] at @s if entity @e[type=armor_stand,tag=bestiary.village.name,distance=..$(village_heal_distance)] run effect give @s regeneration 5 0 true
