# --- Stamp new tab entities with session ---
scoreboard players operation #gui_stamp ec.temp = @s adv.gui_session
execute as @e[type=text_display,tag=CK.TabEl,distance=..5] unless score @s adv.gui_session matches 1.. run scoreboard players operation @s adv.gui_session = #gui_stamp ec.temp
execute as @e[type=interaction,tag=CK.TabEl,distance=..5] unless score @s adv.gui_session matches 1.. run scoreboard players operation @s adv.gui_session = #gui_stamp ec.temp

# --- Update nav arrow colors ---
# [<] gray on page 0, gold on page 1
execute if score @s ec.ck_tab_page matches 0 as @e[type=text_display,tag=CK.TabPrevText,distance=..5,limit=1] if score @s adv.gui_session = #gui_check ec.temp run data modify entity @s text set value {"text":"[<]","color":"dark_gray"}
execute if score @s ec.ck_tab_page matches 1 as @e[type=text_display,tag=CK.TabPrevText,distance=..5,limit=1] if score @s adv.gui_session = #gui_check ec.temp run data modify entity @s text set value {"text":"[<]","color":"gold","bold":true}
# [>] gold on page 0, gray on page 1
execute if score @s ec.ck_tab_page matches 0 as @e[type=text_display,tag=CK.TabNextText,distance=..5,limit=1] if score @s adv.gui_session = #gui_check ec.temp run data modify entity @s text set value {"text":"[>]","color":"gold","bold":true}
execute if score @s ec.ck_tab_page matches 1 as @e[type=text_display,tag=CK.TabNextText,distance=..5,limit=1] if score @s adv.gui_session = #gui_check ec.temp run data modify entity @s text set value {"text":"[>]","color":"dark_gray"}
