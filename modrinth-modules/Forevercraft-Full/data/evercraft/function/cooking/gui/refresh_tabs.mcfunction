# ============================================================
# Campfire Kitchen GUI — Refresh Tabs (Paginated)
# Runs as the player. Kills existing tabs, spawns current page.
# Page 0: tabs 0-5 (Combat..Seasonal), Page 1: tabs 6-10 (Treats..Spirit)
# Tab positions: 6 slots at 0.48 spacing, y=0.50
# ============================================================

# Kill existing tab entities
scoreboard players operation #gui_check ec.temp = @s adv.gui_session
execute as @e[type=text_display,tag=CK.TabEl,distance=..5] if score @s adv.gui_session = #gui_check ec.temp run kill @s
execute as @e[type=interaction,tag=CK.TabEl,distance=..5] if score @s adv.gui_session = #gui_check ec.temp run kill @s

# Initialize tab page if unset
execute unless score @s ec.ck_tab_page matches 0..1 run scoreboard players set @s ec.ck_tab_page 0

# === PAGE 0: Combat, Mining, Fortune, Wayfarer, Delicacy, Seasonal ===
# Tab 0: Combat
execute if score @s ec.ck_tab_page matches 0 unless score @s ec.ck_cat matches 0 facing entity @n[type=marker,tag=CK.Anchor,distance=..5] feet rotated ~ 0 positioned ^ ^2.05 ^2.3 positioned ^1.10 ^0.50 ^0 run summon text_display ~ ~ ~ {brightness:{block:15,sky:15},shadow_radius:0f,Tags:["CK.MenuEl","CK.TabEl","CK.Tab0Text"],billboard:"center",text:{"text":"[Combat]","color":"gray"},transformation:{left_rotation:[0f,0f,0f,1f],right_rotation:[0f,0f,0f,1f],translation:[0f,0f,0f],scale:[0.338f,0.338f,0.338f]}}
execute if score @s ec.ck_tab_page matches 0 if score @s ec.ck_cat matches 0 facing entity @n[type=marker,tag=CK.Anchor,distance=..5] feet rotated ~ 0 positioned ^ ^2.05 ^2.3 positioned ^1.10 ^0.50 ^0 run summon text_display ~ ~ ~ {brightness:{block:15,sky:15},shadow_radius:0f,Tags:["CK.MenuEl","CK.TabEl","CK.Tab0Text"],billboard:"center",text:{"text":"[Combat]","color":"yellow","bold":true},transformation:{left_rotation:[0f,0f,0f,1f],right_rotation:[0f,0f,0f,1f],translation:[0f,0f,0f],scale:[0.338f,0.338f,0.338f]}}
execute if score @s ec.ck_tab_page matches 0 facing entity @n[type=marker,tag=CK.Anchor,distance=..5] feet rotated ~ 0 positioned ^ ^2.07 ^2.3 positioned ^1.10 ^0.44 ^0 run summon interaction ~ ~ ~ {Tags:["CK.MenuEl","CK.TabEl","CK.Tab0Click"],width:0.3f,height:0.06f,response:1b}

