# Spawn a summon list entry at the correct row position
# Row 0 at ^2.10, each subsequent row -0.07

# Calculate Y offset: 1.75 - (row * 0.07) — pre-computed per row since macro math is limited
$execute if score #bd_summon_row ec.temp matches 0 rotated ~ 0 positioned ^ ^2.10 ^2.26 run summon text_display ~ ~ ~ {brightness:{block:15,sky:15},shadow_radius:0f,Tags:["bd.summon_content","bd.summon_entry","companion.menuelement"],billboard:"center",text:[{"text":""},$(entry_name),{"text":"$(entry_tag)","color":"gold"}],background:0,shadow:1b,transformation:{left_rotation:[0f,0f,0f,1f],right_rotation:[0f,0f,0f,1f],translation:[0f,0f,0f],scale:[0.338f,0.338f,0.338f]}}
